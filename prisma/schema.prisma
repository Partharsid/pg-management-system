generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MANAGER
  TENANT
}

enum BedStatus {
  VACANT
  OCCUPIED
  MAINTENANCE
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
  DORMITORY
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  LEFT
}

enum InvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  OTHER
}

enum ExpenseCategory {
  ELECTRICITY
  WATER
  GROCERIES
  MAINTENANCE
  SALARY
  INTERNET
  GAS
  RENT
  OTHER
}

enum IdProofType {
  AADHAR
  PAN
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  OTHER
}

enum ReminderType {
  EMAIL
  SMS
  WHATSAPP
  SYSTEM
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  phone           String?
  role            Role
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  managedProperties Property[] @relation("PropertyManager")
  recordedExpenses  Expense[]  @relation("ExpenseRecorder")
  recordedPayments  Payment[]  @relation("PaymentRecorder")
  tenant            Tenant?

  @@index([email])
  @@index([role])
}

model Property {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  managerId   String?
  manager     User?    @relation("PropertyManager", fields: [managerId], references: [id])
  rooms       Room[]
  expenses    Expense[]

  @@index([managerId])
}

model Room {
  id          String    @id @default(cuid())
  roomNumber  String
  floor       Int       @default(0)
  roomType    RoomType  @default(SINGLE)
  baseRent    Decimal   @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  beds        Bed[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId])
}

model Bed {
  id          String     @id @default(cuid())
  bedNumber   String
  status      BedStatus  @default(VACANT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  roomId      String
  room        Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant      Tenant?

  @@unique([roomId, bedNumber])
  @@index([roomId])
  @@index([status])
}

model Tenant {
  id                    String       @id @default(cuid())
  name                  String
  email                 String?
  phone                 String
  idProofType           IdProofType  @default(OTHER)
  idProofNumber         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  dateOfJoining         DateTime
  dateOfLeaving         DateTime?
  baseRent              Decimal      @db.Decimal(10, 2)
  securityDeposit       Decimal?     @db.Decimal(10, 2)
  status                TenantStatus @default(ACTIVE)
  notes                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  userId   String?  @unique
  user     User?    @relation(fields: [userId], references: [id])
  bedId    String?  @unique
  bed      Bed?     @relation(fields: [bedId], references: [id])
  invoices Invoice[]
  payments Payment[]
  reminders Reminder[]

  @@index([status])
  @@index([bedId])
  @@index([phone])
}

model Invoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique
  month             Int
  year              Int
  baseRent          Decimal       @db.Decimal(10, 2)
  electricityCharge Decimal?      @db.Decimal(10, 2)
  waterCharge       Decimal?      @db.Decimal(10, 2)
  otherCharges      Decimal?      @db.Decimal(10, 2)
  totalAmount       Decimal       @db.Decimal(10, 2)
  paidAmount        Decimal       @default(0) @db.Decimal(10, 2)
  status            InvoiceStatus @default(PENDING)
  dueDate           DateTime
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments  Payment[]
  reminders Reminder[]

  @@unique([tenantId, month, year])
  @@index([tenantId])
  @@index([status])
  @@index([month, year])
}

model Payment {
  id              String      @id @default(cuid())
  amount          Decimal     @db.Decimal(10, 2)
  paymentDate     DateTime
  paymentMode     PaymentMode @default(CASH)
  referenceNumber String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId     String?
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])
  recordedById  String?
  recordedBy    User?    @relation("PaymentRecorder", fields: [recordedById], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([paymentDate])
}

model Expense {
  id            String           @id @default(cuid())
  category      ExpenseCategory
  description   String
  amount        Decimal          @db.Decimal(10, 2)
  expenseDate   DateTime
  receipt       String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  propertyId    String
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  recordedById  String?
  recordedBy    User?     @relation("ExpenseRecorder", fields: [recordedById], references: [id])

  @@index([propertyId])
  @@index([category])
  @@index([expenseDate])
}

model Reminder {
  id        String         @id @default(cuid())
  type      ReminderType
  status    ReminderStatus @default(PENDING)
  message   String
  sentAt    DateTime?
  createdAt DateTime       @default(now())

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([status])
}
